# Used by forge script Deploy.s.sol / Seed.s.sol
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
SNOWTRACE_API_KEY=

# Deployer wallet — fund with AVAX from https://core.app/tools/testnet-faucet
DEPLOYER_PRIVATE_KEY=

# Optional: if unset, Deploy.s.sol deploys a MockUSDC.
USDC_ADDRESS=

# Address that signs attestations off-chain. Must match the wallet your edge
# function uses (ISSUER_PRIVATE_KEY in supabase env). If set, Deploy.s.sol calls
# IssuerRegistry.addIssuer(<this>).
INITIAL_ISSUER_ADDRESS=

# For Seed.s.sol
DEMO_LENDER_ADDRESS=
DEMO_BORROWER_ADDRESS=
NEXT_PUBLIC_LENDING_POOL_ADDRESS=
